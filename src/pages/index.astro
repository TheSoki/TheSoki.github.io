---
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import AboutMe from '@/components/homepage/AboutMe.astro';
import AboutSkills from '@/components/homepage/AboutSkills.astro';
import Brands from '@/components/homepage/Brands.astro';
import Education from '@/components/homepage/Education.astro';
import Experience from '@/components/homepage/Experience.astro';
import MyQualities from '@/components/homepage/MyQualities.astro';
import Portfolio from '@/components/homepage/Portfolio.astro';
import SaidAboutMe from '@/components/homepage/SaidAboutMe.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import Layout from '@/layouts/Layout.astro';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main>
    <div class="min-h-screen">
      <Header />
      <AboutMe />
    </div>

    <MyQualities />
    <Portfolio />
    <Education />
    <AboutSkills />
    <Experience />
    <Brands />
    <SaidAboutMe />

    <Footer />
  </main>
</Layout>
