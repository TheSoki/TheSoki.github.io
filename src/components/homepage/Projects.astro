---
import { Image } from 'astro:assets';
import vsbImage from '@/images/projects/vsb.webp';
import lemenioImage from '@/images/projects/lemenio.png';

const education = [
  {
    year: '2/2022 - 4/2022',
    image: vsbImage,
    imageStyle: 'mb-2 w-1/3 mx-auto',
    position: 'Mobile App Developer',
    company: 'VŠB',
    description: `<span class="not-italic">👨‍🎓</span> New app for university students. VŠB APP </br>
    I was introduced to an app in a terrible state, requiring a ground-up rewrite.
    I proceeded to develop new features and release the first version of the app <span class="not-italic">🎉</span></br>.
    Built with TypeScript, React Native and Expo.
    `,
  },
  {
    year: '8/2022 - 4/2023',
    image: lemenioImage,
    imageStyle: 'mb-2',
    position: 'Full-Stack Developer',
    company: 'Lemenio',
    description: `<span class="not-italic">🏫</span> Design and development 'from scratch' of learning system for students and teachers of a language school. </br>
    <span class="not-italic">👨‍💻</span> Technologies: TypeScript, React, Tailwind CSS, NextJS, tRPC, Docker, PostgreSQL </br>
    <span class="not-italic">📝</span> My responsibilities included overall system architecture design, feature design and development, deployment, and the initial launch.`,
  },
];
---

<section class="py-10 md:py-16">
  <div class="container mx-auto max-w-screen-xl px-4">
    <h1 class="mb-5 text-3xl font-medium text-gray-700 md:text-4xl">Projects</h1>

    <p class="mb-8 text-base font-normal text-gray-500">
      Sometimes, I engage in external passion projects, bringing a touch of enjoyment to my coding pursuits. Here are
      some of my favorites.
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        education.reverse().map(({ year, image, imageStyle, position, company, description }) => (
          <div class="rounded-md bg-gray-50 px-8 py-10">
            <Image src={image} alt={`${company} project`} class={imageStyle} />
            <time class="mb-1 text-sm font-normal text-gray-400">{year}</time>
            <h3 class="text-xl font-semibold text-gray-600">{position}</h3>
            <p class="mb-1 text-sm font-normal text-gray-400">{company}</p>

            <p class="mb-4 text-base font-normal italic text-gray-500" set:html={description} />
          </div>
        ))
      }
    </div>
  </div>
</section>
