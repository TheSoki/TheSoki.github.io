---
import { Image } from 'astro:assets';
import brandImage from '../../images/brand.webp';
---

<section class="py-10 md:py-16">
  <div class="container mx-auto max-w-screen-xl px-4">
    <h1 class="mb-5 text-3xl font-medium text-gray-700 md:text-4xl">Brands</h1>

    <p class="mb-10 text-xs font-normal text-gray-500 md:mb-20 md:text-base">
      Below is a summary of the places I studied
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      <Image src={brandImage} alt="Brand" />

      <Image src={brandImage} alt="Brand" />

      <Image src={brandImage} alt="Brand" />

      <Image src={brandImage} alt="Brand" />

      <Image src={brandImage} alt="Brand" />

      <Image src={brandImage} alt="Brand" />
    </div>
  </div>
</section>
