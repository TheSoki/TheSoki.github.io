{
  "name": "thesoki-github-io",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && npx @divriots/jampack ./dist",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx,astro}\"",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx,json,md,mdx,astro}\" . --max-warnings=0",
    "typecheck": "tsc --pretty --noEmit",
    "integrate": "pnpm run lint && pnpm run typecheck",
    "prepare": "husky install",
    "commit-msg": "devmoji -e --lint",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@astrojs/check": "^0.3.1",
    "@astrojs/sitemap": "^3.0.3",
    "@astrojs/tailwind": "^5.0.3",
    "@divriots/jampack": "^0.22.1",
    "astro": "^4.0.3",
    "astro-icon": "^0.8.2",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "devmoji": "^2.3.0",
    "eslint": "^8.55.0",
    "eslint-plugin-astro": "^0.30.0",
    "eslint-plugin-markdown": "^3.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "prettier-plugin-astro": "^0.12.2",
    "prettier-plugin-tailwindcss": "^0.5.9"
  },
  "lint-staged": {
    "*": "prettier --write"
  }
}
