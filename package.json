{
  "name": "thesoki-github-io",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx,astro}\"",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx,json,md,mdx,astro}\" . --max-warnings=0",
    "typecheck": "tsc --pretty --noEmit",
    "integrate": "pnpm run lint && pnpm run typecheck",
    "prepare": "husky install",
    "commit-msg": "devmoji -e --lint",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@astrojs/check": "^0.3.1",
    "@astrojs/sitemap": "^3.0.3",
    "@astrojs/tailwind": "^5.0.2",
    "astro": "^3.5.5",
    "astro-icon": "^0.8.1",
    "sharp": "^0.32.6",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "devmoji": "^2.3.0",
    "eslint": "^8.53.0",
    "eslint-plugin-astro": "^0.29.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "prettier-plugin-astro": "^0.12.2",
    "prettier-plugin-tailwindcss": "^0.5.7"
  },
  "lint-staged": {
    "*": "prettier --write"
  }
}
